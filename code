#include <Wire.h>
#include <U8g2lib.h>
#include <math.h>

U8G2_SSD1306_128X64_NONAME_F_HW_I2C u8g2(U8G2_R0, U8X8_PIN_NONE);

#define JOY_X 35
#define JOY_Y 34
#define JOY_SW 27
#define BUZZER 13

#define TILE 8
#define PAC_SPEED 0.16
#define GHOST_SPEED 0.13

const char* maze[8] = {
  "################",
  "#..............#",
  "#.####.##.####.#",
  "#..............#",
  "#.##.######.##.#",
  "#..............#",
  "#.####....####.#",
  "################"
};

char mapData[8][17];

struct Entity{
  float x;
  float y;
  int dirX;
  int dirY;
};

Entity pac = {1,1,1,0};
Entity ghost1 = {14,1,-1,0};
Entity ghost2 = {14,5,-1,0};

int queuedDirX = 1;
int queuedDirY = 0;

int centerX=0;
int centerY=0;

bool mouth=false;
bool blinkPellet=false;
int score=0;
int lives=3;

const unsigned char pacSprite1[] PROGMEM = {0x3C,0x7E,0xFC,0xF8,0xFC,0x7E,0x3C,0x00};
const unsigned char pacSprite2[] PROGMEM = {0x3C,0x7E,0xF0,0xE0,0xF0,0x7E,0x3C,0x00};
const unsigned char ghostSprite[] PROGMEM = {0x3C,0x7E,0xDB,0xFF,0xFF,0xDB,0xFF,0x00};

void copyMaze(){
  for(int y=0;y<8;y++) strcpy(mapData[y], maze[y]);
}

bool wallAt(int x,int y){
  if(x<0||x>15||y<0||y>7) return true;
  return mapData[y][x]=='#';
}

void calibrateJoystick(){
  long sx=0, sy=0;
  for(int i=0;i<20;i++){
    sx += analogRead(JOY_X);
    sy += analogRead(JOY_Y);
    delay(10);
  }
  centerX = sx/20;
  centerY = sy/20;
}

void wakaSound(){
  ledcWriteTone(0,850);
  delay(4);
  ledcWriteTone(0,0);
}

void deathSound(){
  for(int i=1000;i>150;i-=60){
    ledcWriteTone(0,i);
    delay(7);
  }
  ledcWriteTone(0,0);
}

void introScreen(){
  for(int i=0;i<2;i++){
    u8g2.clearBuffer();
    u8g2.setFont(u8g2_font_logisoso18_tf);
    u8g2.drawStr(10,28,"PACMAN");
    u8g2.setFont(u8g2_font_6x10_tf);
    u8g2.drawStr(26,48,"ESP32 MASTER");
    u8g2.sendBuffer();
    wakaSound();
    delay(400);

    u8g2.clearBuffer();
    u8g2.setFont(u8g2_font_6x13_tf);
    u8g2.drawStr(34,32,"LOADING...");
    u8g2.sendBuffer();
    delay(220);
  }
}

void drawHUD(){
  u8g2.drawFrame(0,0,128,64);
  u8g2.setFont(u8g2_font_5x8_tf);

  char buf[20];
  sprintf(buf,"S:%d",score);
  u8g2.drawStr(2,62,buf);

  sprintf(buf,"L:%d",lives);
  u8g2.drawStr(55,62,buf);
}

void drawMaze(){
  for(int y=0;y<8;y++){
    for(int x=0;x<16;x++){
      if(mapData[y][x]=='#'){
        u8g2.drawBox(x*TILE,y*TILE,TILE,TILE);
      }
      if(mapData[y][x]=='.' && blinkPellet){
        u8g2.drawDisc(x*TILE+4,y*TILE+4,1);
      }
    }
  }
}

void drawPac(){
  int px = pac.x*TILE;
  int py = pac.y*TILE;
  if(mouth) u8g2.drawXBMP(px,py,8,8,pacSprite1);
  else u8g2.drawXBMP(px,py,8,8,pacSprite2);
}

void drawGhost(Entity g){
  int gx = g.x*TILE;
  int gy = g.y*TILE;
  u8g2.drawXBMP(gx,gy,8,8,ghostSprite);
}

bool nearCenter(Entity e){
  return (abs(e.x-round(e.x))<0.08 && abs(e.y-round(e.y))<0.08);
}

void readJoystickQueue(){
  int xVal = analogRead(JOY_X);
  int yVal = analogRead(JOY_Y);

  int dx = xVal-centerX;
  int dy = yVal-centerY;

  int threshold = 700;

  if(abs(dx)>abs(dy)){
    if(dx<-threshold){queuedDirX=-1; queuedDirY=0;}
    else if(dx>threshold){queuedDirX=1; queuedDirY=0;}
  }else{
    if(dy<-threshold){queuedDirX=0; queuedDirY=-1;}
    else if(dy>threshold){queuedDirX=0; queuedDirY=1;}
  }
}

void movePac(){
  readJoystickQueue();

  if(nearCenter(pac)){
    pac.x = round(pac.x);
    pac.y = round(pac.y);

    int cx = pac.x;
    int cy = pac.y;

    if(!wallAt(cx+queuedDirX, cy+queuedDirY)){
      pac.dirX = queuedDirX;
      pac.dirY = queuedDirY;
    }
  }

  int nextX = round(pac.x + pac.dirX*0.51);
  int nextY = round(pac.y + pac.dirY*0.51);

  if(!wallAt(nextX,nextY)){
    pac.x += pac.dirX*PAC_SPEED;
    pac.y += pac.dirY*PAC_SPEED;
  }

  int tx = round(pac.x);
  int ty = round(pac.y);

  if(mapData[ty][tx]=='.'){
    mapData[ty][tx]=' ';
    score++;
    wakaSound();
  }
}

void moveGhost(Entity &g){
  if(nearCenter(g)){
    g.x = round(g.x);
    g.y = round(g.y);

    int cx = g.x;
    int cy = g.y;

    int options[4][2]={{1,0},{-1,0},{0,1},{0,-1}};
    int best=9999;
    int bestdx=g.dirX;
    int bestdy=g.dirY;

    for(int i=0;i<4;i++){
      int dx=options[i][0];
      int dy=options[i][1];

      if(wallAt(cx+dx,cy+dy)) continue;

      int dist = abs((cx+dx)-round(pac.x)) + abs((cy+dy)-round(pac.y));

      if(dist<best){
        best=dist;
        bestdx=dx;
        bestdy=dy;
      }
    }

    g.dirX=bestdx;
    g.dirY=bestdy;
  }

  int nextX = round(g.x + g.dirX*0.51);
  int nextY = round(g.y + g.dirY*0.51);

  if(!wallAt(nextX,nextY)){
    g.x += g.dirX*GHOST_SPEED;
    g.y += g.dirY*GHOST_SPEED;
  }
}

bool hitGhost(){
  float d1 = sqrt(pow(pac.x-ghost1.x,2)+pow(pac.y-ghost1.y,2));
  float d2 = sqrt(pow(pac.x-ghost2.x,2)+pow(pac.y-ghost2.y,2));
  return (d1<0.45 || d2<0.45);
}

void resetGame(){
  score=0;
  lives=3;
  pac={1,1,1,0};
  ghost1={14,1,-1,0};
  ghost2={14,5,-1,0};
  queuedDirX=1;
  queuedDirY=0;
  copyMaze();
}

void gameOverScreen(){
  deathSound();
  u8g2.clearBuffer();
  u8g2.setFont(u8g2_font_logisoso18_tf);
  u8g2.drawStr(8,30,"GAME");
  u8g2.drawStr(10,58,"OVER");
  u8g2.sendBuffer();
  delay(1000);
  resetGame();
}

void setup(){
  u8g2.begin();

  pinMode(JOY_SW,INPUT_PULLUP);
  pinMode(BUZZER,OUTPUT);

  analogReadResolution(12);
  analogSetAttenuation(ADC_11db);

  ledcAttach(BUZZER, 5000, 8);

  randomSeed(analogRead(32));

  copyMaze();
  calibrateJoystick();
  introScreen();
}

void loop(){
  movePac();
  moveGhost(ghost1);
  moveGhost(ghost2);

  mouth=!mouth;
  blinkPellet=!blinkPellet;

  u8g2.clearBuffer();
  drawMaze();
  drawPac();
  drawGhost(ghost1);
  drawGhost(ghost2);
  drawHUD();
  u8g2.sendBuffer();

  if(hitGhost()){
    lives--;
    deathSound();
    pac.x=1;
    pac.y=1;
    pac.dirX=1;
    pac.dirY=0;
    delay(250);
    if(lives<=0) gameOverScreen();
  }

  if(!digitalRead(JOY_SW)){
    resetGame();
    delay(250);
  }

  delay(28);
}
